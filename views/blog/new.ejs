<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>New Post · Blogify</title>
  <link rel="stylesheet" href="/css/blog.css"/>
    <link rel="stylesheet" href="/css/navbar.css">
</head>
<body>

 <!-- Navigation -->
    <%- include('../includes/navbar')%>
  <main class="container container-sm">

    <div class="page-header">
      <h1>Write a new post</h1>
      <p>Share your thoughts with the world</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">⚠ <%= error %></div>
    <% } %>

    <form action="/blog/new" method="POST" enctype="multipart/form-data" class="blog-form">

      <!-- Cover Image -->
      <div class="cover-upload">
        <div class="cover-preview" id="coverPreview">
          <img id="coverImg" src="/images/uploads/default-cover.png" alt="Cover preview"/>
          <label for="coverImage" class="cover-overlay">
            <span>🖼 Choose cover image</span>
          </label>
        </div>
        <input type="file" id="coverImage" name="coverImage" accept="image/jpeg,image/png,image/webp" hidden/>
        <p class="hint">JPG, PNG, WEBP · Max 5MB · Recommended 1200×630</p>
      </div>

  
      <div class="form-group">
        <label for="title">Title <span class="req">*</span></label>
        <input
          type="text"
          id="title"
          name="title"
          placeholder="Write an engaging title..."
          value="<%= formData.title || '' %>"
          maxlength="150"
          required
        />
        <p class="char-count"><span id="titleCount">0</span> / 150</p>
      </div>

      <div class="form-group">
        <label for="content">Content <span class="req">*</span></label>
        <textarea
          id="content"
          name="content"
          placeholder="Write your story here..."
          rows="14"
          required
        ><%= formData.content || '' %></textarea>
      </div>

      <div class="form-actions">
        <a href="/blog" class="btn-cancel">Cancel</a>
        <button type="submit" class="btn-primary">Publish post →</button>
      </div>

    </form>
  </main>

  <script>
    // Cover image preview
    document.getElementById("coverImage").addEventListener("change", function () {
      const file = this.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { alert("Max 5MB."); this.value = ""; return; }
      const reader = new FileReader();
      reader.onload = e => document.getElementById("coverImg").src = e.target.result;
      reader.readAsDataURL(file);
    });

    // Title character count
    const titleInput = document.getElementById("title");
    const titleCount = document.getElementById("titleCount");
    titleCount.textContent = titleInput.value.length;
    titleInput.addEventListener("input", () => {
      titleCount.textContent = titleInput.value.length;
    });
  </script>
</body>
</html>
