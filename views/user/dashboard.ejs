<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard · Blogify</title>
  <link rel="stylesheet" href="/css/blog.css"/>
  <link rel="stylesheet" href="/css/dashboard.css"/>
    <link rel="stylesheet" href="/css/navbar.css">
</head>
<body>

  <!-- Navbar -->
  <%- include('../includes/navbar'); %>
  <main class="container">

    <!-- Profile Summary -->
    <div class="profile-banner">
      <img
        src="<%= user.avatar.url %>"
        alt="<%= user.username %>"
        class="profile-avatar"
        onerror="this.src='/images/uploads/default-avatar.png'"
      />
      <div class="profile-info">
        <h1><%= user.fullname || user.username %></h1>
        <p class="profile-username">@<%= user.username %></p>
        <p class="profile-email">✉ <%= user.email %></p>
      </div>
      <div class="profile-stats">
        <div class="stat">
          <span class="stat-number"><%= blogs.length %></span>
          <span class="stat-label">Post<%= blogs.length !== 1 ? 's' : '' %></span>
        </div>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">⚠ <%= error %></div>
    <% } %>

    <!-- Section Header -->
    <div class="section-header">
      <h2>Your Posts</h2>
      <a href="/blog/new" class="btn-new">+ New Post</a>
    </div>

    <!-- Empty State -->
    <% if (blogs.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">✍</div>
        <h2>No posts yet</h2>
        <p>You haven't written anything yet. Start writing!</p>
        <a href="/blog/new" class="btn-primary">Write your first post</a>
      </div>

    <% } else { %>

      <!-- Blog List -->
      <div class="dash-list">
        <% blogs.forEach(blog => { %>
          <div class="dash-card">

            <!-- Cover -->
            <a href="/blog/<%= blog._id %>" class="dash-cover-link">
              <img
                src="<%= blog.coverImage.url %>"
                alt="<%= blog.title %>"
                class="dash-cover"
                onerror="this.src='/images/uploads/default-cover.png'"
              />
            </a>

            <!-- Info -->
            <div class="dash-info">
              <a href="/blog/<%= blog._id %>" class="dash-title"><%= blog.title %></a>
              <p class="dash-excerpt">
                <%= blog.content.substring(0, 100) %><%= blog.content.length > 100 ? '...' : '' %>
              </p>
              <p class="dash-date">
                🕐 <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              </p>
            </div>

            <!-- Actions -->
            <div class="dash-actions">
              <a href="/blog/<%= blog._id %>" class="dash-btn dash-btn-view">👁 View</a>
              <a href="/blog/<%= blog._id %>/edit" class="dash-btn dash-btn-edit">✏ Edit</a>
              <form action="/blog/<%= blog._id %>/delete" method="POST" onsubmit="return confirm('Delete this post?')">
                <button type="submit" class="dash-btn dash-btn-delete">🗑 Delete</button>
              </form>
            </div>

          </div>
        <% }) %>
      </div>

    <% } %>

  </main>

</body>
</html>
